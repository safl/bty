#cloud-config
# bty server appliance - base cloud-init userdata
#
# Tokens substituted by scripts/gen_userdata.py:
#   __BTY_HOSTNAME__   - hostname for the appliance
#   __BTY_TIMEZONE__   - IANA timezone
#
# Files under rootfs/common/ and rootfs/server/ are appended as a
# write_files block by gen_userdata.py. The bty-lab wheel staged by
# scripts/bty_wheel_stage.py rides through there as well.

hostname: __BTY_HOSTNAME__
fqdn: __BTY_HOSTNAME__.local
manage_etc_hosts: true

timezone: __BTY_TIMEZONE__

# trixie-backports for newer kernel + firmware. Stock trixie ships
# kernel 6.12.x; some recent consumer NICs (Realtek RTL8125/8126
# 2.5GbE on mini-PCs, Intel I225/I226) and WiFi chipsets (rtw89,
# mt7925) only see solid in-tree driver support in 6.13+. Backports
# rebuilds the latest stable kernel from sid/testing for trixie;
# signed by the same archive key, so no extra keyring handling.
#
# The apt preference file
# rootfs/server/etc/apt/preferences.d/99-bty-backports.pref is
# deployed via write_files (init stage) and pins linux-image-amd64
# + firmware-* to this archive so the candidate version apt picks
# during cc_package_update_upgrade_install is the backports one.
apt:
  sources:
    debian-backports.list:
      source: "deb http://deb.debian.org/debian trixie-backports main non-free-firmware"

# Build VM only - the cooked image's runcmd locks the bake-VM root
# password (``passwd -l root``) so this seed credential cannot be
# used after the bake. ``ssh_pwauth: true`` here just lets cloud-
# init complete; sshd's PasswordAuthentication setting on the
# cooked image is unchanged from Debian's default (yes, so
# operators can ``ssh odus@<ip>`` per /etc/issue).
ssh_pwauth: true
chpasswd:
  expire: false
  list: |
    root:root

# Server is persistent: let cloud-init grow root to fill the disk on
# first boot. Image library / TFTP / iPXE assets live on the same
# rootfs -- one filesystem to grow keeps first-boot logic simple,
# and the bty image store carves out its own labelled partition
# when the operator opts in via ``bty-image-store-init``.
package_update: true
package_upgrade: false
packages:
  # bty runtime + its [web] extra's transitive build hooks.
  - python3
  - python3-venv
  - git
  - curl
  - ca-certificates
  # PXE boot stack. dnsmasq runs TFTP and (when the operator
  # activates it) proxy-DHCP. ``ipxe`` ships the BIOS + UEFI binaries.
  - dnsmasq
  - ipxe
  # ``cloud-utils`` ships ``growpart`` which ``bty-grow-rootfs.service``
  # uses on first boot to expand the rootfs partition to fill the
  # operator's disk (the cooked image is baked at a fixed 6 GiB).
  - cloud-utils
  # Userspace entropy fallback. Modern x86 CPUs (Ivy Bridge / Alder
  # Lake / etc.) have RDRAND and Debian's kernel ships
  # ``CONFIG_RANDOM_TRUST_CPU=y`` so the CSPRNG fills before
  # userspace starts. But: a VM without virtio-rng, an old
  # CPU without RDRAND, or a kernel built with CONFIG_RANDOM_TRUST_
  # CPU=n can leave services blocking on ``getrandom()`` for
  # minutes during early boot. ``haveged`` runs as a tiny daemon,
  # generates entropy from CPU jitter, and feeds the kernel pool
  # so ``getrandom()`` never blocks. Defense-in-depth; no harm
  # on hardware that already has plenty of entropy.
  - haveged
  # Firmware + bare-metal kernel for whatever hardware bty-server
  # lands on. The cloud-image baseline ships a slim
  # ``linux-image-cloud-amd64`` plus ~no firmware -- cloud VMs
  # don't need wireless / GPU / Realtek NIC blobs, but bare metal
  # does. Without firmware the kernel probes the device, times
  # out after 60-120s per probe, retries -- compounding to
  # multi-minute unexplained early-boot waits.
  #
  # ``firmware-linux-nonfree`` is the metapackage that Depends on
  # every individual ``firmware-*`` nonfree package (realtek,
  # iwlwifi, atheros, brcm80211, mediatek, ath11k, bnx2/bnx2x,
  # netronome, nvidia-graphics, amd-graphics, misc-nonfree, ...).
  # ``linux-image-amd64`` plus the trixie-backports pin (see the
  # ``apt:`` block + the preferences file under rootfs/server)
  # land the newest kernel Debian ships, which carries newer
  # in-tree drivers (r8169 with RTL8125/8126 fixes, rtw89, etc.).
  # Curated trimming was tried in earlier releases; recurring
  # Realtek + WiFi failures on consumer mini-PCs drove the
  # reversal.
  - linux-image-amd64
  - firmware-linux-nonfree
  # ``firmware-realtek`` is explicit (also pulled transitively by
  # firmware-linux-nonfree) so the package list visibly advertises
  # Realtek 2.5GbE NIC support: RTL8125 / RTL8125B / RTL8126 on
  # GMKTec NUCBOX G10 (Ryzen 5) and the wider mini-PC ecosystem.
  - firmware-realtek
  # DKMS build environment for the out-of-tree ``r8125`` driver.
  # See the ``r8125-dkms`` runcmd block below: the in-tree
  # ``r8169`` in kernel 6.13+ nominally covers the RTL8125 family
  # but some consumer mini-PCs (GMKTec G10) need the upstream
  # Realtek r8125 source. linux-headers-amd64 is pinned to
  # trixie-backports via 99-bty-backports.pref so the headers
  # match the linux-image-amd64 the bake installs. ``git`` is
  # already in the list above. dkms + build-essential stay on
  # the appliance because the operator may upgrade kernels later
  # and DKMS rebuilds the module against the new kernel
  # automatically.
  - dkms
  - build-essential
  - linux-headers-amd64
  # ``parted`` is used by ``bty-image-store-init`` to partition a
  # 2nd disk for the persistent image cache. It's almost certainly
  # already pulled in transitively (cloud-utils' growpart shells out
  # to parted), but list it explicitly so the dependency doesn't
  # depend on what cloud-utils Recommends in some future Debian.
  - parted
  # Plymouth is intentionally NOT installed on the server appliance:
  # its quit/teardown emits VT100 escape sequences to
  # ``/dev/console``, and on a server with the standard
  # ``console=ttyS0,115200 console=tty0`` kernel cmdline that means
  # garbage like ``[?7h[6;32766H`` lands on the serial console right
  # before agetty draws the login banner. The figlet banner in
  # /etc/issue + /etc/motd is the appliance's identity layer for
  # the headless case; a graphical splash adds no operational value
  # on a box the operator interacts with via SSH or the browser UI.
  # ``tests/test_smoke.py::test_server_cloudinit_does_not_install_plymouth``
  # pins this so a "let's add the splash back" attempt gets caught
  # by tests rather than by a fresh appliance boot.

runcmd:
  # Install bty-lab[web] from the staged wheel into a system venv,
  # then create the dedicated 'bty' service user. The wheel filename
  # carries a version we don't pin here, so we glob for it.
  #
  # Default credentials: ``bty / bty``. PAM auth gates ``bty-web``,
  # so the appliance ships with a known login the operator can use
  # immediately - same model as PiKVM (admin/admin), Raspberry Pi OS
  # (pi/raspberry), Octoprint, etc. Rotate with ``sudo passwd bty``
  # before exposing the appliance to anything beyond a trusted
  # network. The shell is left as ``/usr/sbin/nologin`` (standard
  # service-user shape); PAM's ``login`` service used by bty-web's
  # ``pamela.authenticate`` doesn't check the shell - it just reads
  # /etc/shadow to verify the password.
  - |
    set -eu
    useradd --system --no-create-home --shell /usr/sbin/nologin bty
    echo 'bty:bty' | chpasswd
    install -d -o root -g root -m 0755 /opt/bty
    python3 -m venv /opt/bty/venv
    /opt/bty/venv/bin/pip install --no-cache-dir --upgrade pip
    for whl in /opt/bty/bty_lab-*-py3-none-any.whl; do
      /opt/bty/venv/bin/pip install --no-cache-dir "${whl}[web]"
    done
    # Online cijoe: bty-web shells out to ``cijoe`` to run a task
    # against freshly-flashed targets. Same venv, same PATH
    # (``Path(sys.executable).parent / 'cijoe'`` resolves to
    # ``/opt/bty/venv/bin/cijoe`` for the runner).
    /opt/bty/venv/bin/pip install --no-cache-dir cijoe

  # PXE TFTP root: dnsmasq serves the iPXE binaries from here when
  # the operator's router/DHCP tells PXE clients to fetch
  # ``ipxe.efi`` (or an arch sibling) from this appliance.
  #
  # ``ipxe.efi`` is a custom slim build with an embedded chain
  # script that jumps to bty-web's pxe-bootstrap.ipxe -- shipped
  # via cijoe's ``bty_ipxe_build`` step in rootfs/server/var/lib/
  # tftpboot/. Without the embed, stock iPXE's autoboot re-fetches
  # itself in a loop (the operator's DHCP always returns
  # ``filename=ipxe.efi``).
  #
  # ``undionly.kpxe`` for legacy-BIOS PXE clients stays as the
  # Debian-stock symlink (no embed needed there for the homelab
  # path -- BIOS PXE is rare enough that the chain-loop concern
  # is hypothetical, and we keep the bake simple).
  - install -d -o root -g root -m 0755 /var/lib/tftpboot
  - ln -sf /usr/lib/ipxe/undionly.kpxe /var/lib/tftpboot/undionly.kpxe

  # HTTP-Boot path: UEFI HTTPClient targets fetch ipxe.efi over
  # plain HTTP (no TFTP). bty-web serves files from /var/lib/bty/boot,
  # which is also where the custom-built ipxe.efi lands via cijoe's
  # bty_ipxe_build step. Operator configures their router with the
  # HTTPClient bootfile URL pointing at
  # ``http://<bty-server>:8080/boot/ipxe.efi``.
  - install -d -o bty -g bty -m 0755 /var/lib/bty/boot

  # Bake the out-of-tree Realtek r8125 driver into the appliance
  # kernel. The in-tree r8169 in 6.13+ covers RTL8125 / RTL8125B /
  # RTL8126 in theory, but on some consumer mini-PCs (GMKTec
  # NUCBOX G10 in particular) the upstream Realtek r8125 has
  # device-init quirks the in-tree variant hasn't picked up. The
  # narrow modprobe alias (``zz-bty-r8125-prefer.conf`` below)
  # scopes r8125-preference to PCI device IDs 0x8125 and 0x8126
  # ONLY -- machines with RTL8168 / RTL8169 (older 1GbE Realtek)
  # continue to use r8169 unchanged, and machines with no Realtek
  # NIC never auto-load either driver.
  #
  # Pinned to ``master`` of the awesometic packaging; this repo
  # ships the latest Realtek-published source. A specific
  # commit hash can be pinned here if upstream Realtek drift ever
  # introduces a regression.
  - |
    set -eu
    KVER=$(ls /lib/modules | head -1)
    rm -rf /usr/src/r8125-build
    git clone --depth 1 --branch master \
        https://github.com/awesometic/realtek-r8125-dkms.git \
        /usr/src/r8125-build
    R8125_VERSION=$(awk -F'"' '/^PACKAGE_VERSION=/ {print $2}' \
        /usr/src/r8125-build/dkms.conf)
    rm -rf "/usr/src/r8125-${R8125_VERSION}"
    mv /usr/src/r8125-build "/usr/src/r8125-${R8125_VERSION}"
    dkms add -m r8125 -v "${R8125_VERSION}"
    dkms build -m r8125 -v "${R8125_VERSION}" -k "${KVER}"
    dkms install -m r8125 -v "${R8125_VERSION}" -k "${KVER}"
    depmod -a "${KVER}"
    # The awesometic DKMS install may write a flat
    # ``blacklist r8169`` config that would impact non-2.5GbE
    # Realtek hardware (RTL8168 / RTL8169). Remove it and replace
    # with a narrower device-id-scoped alias.
    rm -f /etc/modprobe.d/r8125-dkms.conf \
          /etc/modprobe.d/blacklist-r8169.conf
    cat > /etc/modprobe.d/zz-bty-r8125-prefer.conf <<'EOF'
    # bty: prefer out-of-tree r8125 for the RTL8125 / B and
    # RTL8126 2.5GbE family ONLY. Other Realtek device IDs fall
    # through to in-tree r8169.
    #
    # Operator override (return to in-tree r8169 only):
    #   ln -s /dev/null /etc/modprobe.d/zz-bty-r8125-prefer.conf
    #   update-initramfs -u && reboot
    alias pci:v000010ECd00008125sv*sd*bc*sc*i* r8125
    alias pci:v000010ECd00008126sv*sd*bc*sc*i* r8125
    # Disable Energy-Efficient Ethernet on r8125; some switches
    # auto-negotiate-flap with EEE on.
    options r8125 enable_eee=0
    EOF
    update-initramfs -u -k all

  # bty-web's TFTP daemon-control helper + sudoers entry. The web
  # UI exposes Start/Stop/Restart buttons for dnsmasq.service (which
  # owns the TFTP root). sudo refuses /etc/sudoers.d/* unless mode is
  # exactly 0440.
  - chmod 0755 /usr/local/sbin/bty-web-tftp
  - chmod 0440 /etc/sudoers.d/bty-web
  - chown root:root /etc/sudoers.d/bty-web

  # Privileged helper that prepares a 2nd disk as the bty image store
  # so the operator can reflash the bty-server appliance without
  # losing the image cache. The helper script lives in rootfs/server
  # and gets +x at bake time the same way the PXE helpers do.
  - chmod 0755 /usr/local/sbin/bty-image-store-init

  # ``LABEL=BTY_IMAGE_STORE`` fstab line: if the operator runs
  # ``bty-image-store-init /dev/sdX`` on this appliance, the resulting
  # ext4 filesystem gets that label. The line below auto-mounts the
  # labelled disk at /var/lib/bty/images on every subsequent boot,
  # including after the bty-server appliance is reflashed (because
  # this same line gets baked into the new appliance's /etc/fstab).
  # ``nofail`` means the appliance still boots if no labelled disk
  # is present; bty-web then falls back to storing images on the
  # rootfs. ``x-systemd.device-timeout=10s`` avoids systemd's default
  # 90-second wait when the disk is absent. Idempotent: the bake is
  # one-shot so this only ever runs once; the helper script applies
  # the same guard with ``grep -q`` if the operator wires it up
  # later by hand.
  - |
    set -eu
    if ! grep -qE '^LABEL=BTY_IMAGE_STORE[[:space:]]' /etc/fstab; then
      printf 'LABEL=BTY_IMAGE_STORE /var/lib/bty/images ext4 nofail,x-systemd.device-timeout=10s 0 2\n' \
        >> /etc/fstab
    fi

  # Pick up the staged systemd units. bty-web-init runs once on the
  # cooked image's first boot to set up the state directory tree and
  # write /etc/default/bty-web; bty-web is the long-running service.
  # dnsmasq is enabled so TFTP is up at boot; bty-pxe-proxy.service
  # is shipped DORMANT (ConditionPathExists=/etc/default/bty-pxe-proxy)
  # and only starts once the operator activates PXE through the UI.
  - systemctl daemon-reload
  # ``bty-grow-rootfs.service`` runs once on first boot of the
  # cooked image (sentinel-gated on /var/lib/bty/.rootfs-grown)
  # and expands the rootfs partition to fill the operator's
  # actual disk size. Without it the appliance is stuck at 6 GiB
  # rootfs no matter how big the server's disk is.
  - systemctl enable bty-grow-rootfs.service
  - systemctl enable bty-ssh-host-keys.service
  - systemctl enable bty-web.service bty-web-init.service dnsmasq.service
  # systemd-networkd manages NICs via the .network files we ship in
  # rootfs/server/etc/systemd/network/. The default Debian server
  # image leaves networkd disabled (cloud-init or ifupdown owns the
  # NICs); we explicitly enable it because cloud-init is disabled
  # post-bake. wait-online is the gate ``network-online.target``
  # waits on - bty-web has ``Wants=network-online.target`` so this
  # has to be running too.
  - systemctl enable systemd-networkd.service systemd-networkd-wait-online.service

  # Lock root and create an admin user ``odus`` with passwordless
  # sudo so the operator has shell access for hands-on tasks. SSH
  # password auth stays enabled - the cooked image ships with
  # ``odus:odus`` (and ``bty:bty`` for the web UI). Same model as
  # PiKVM and friends; rotate before exposing.
  - passwd -l root
  - useradd --create-home --shell /bin/bash --groups sudo odus
  - echo 'odus:odus' | chpasswd
  - |
    set -eu
    printf 'odus ALL=(ALL) NOPASSWD:ALL\n' > /etc/sudoers.d/odus
    chown root:root /etc/sudoers.d/odus
    chmod 0440 /etc/sudoers.d/odus

  # Mask default Debian timers / services that aren't useful on an
  # appliance and slow boot down significantly when reading from
  # slow media (USB sticks, SD cards). Each of these does something
  # the operator never asked for: refresh apt indexes / firmware
  # metadata / motd news / man-db cache / fs scrubbing. None of them
  # block the bty-web service starting, but on a stock Debian boot
  # they all wake up around the same time and the kernel/systemd are
  # competing with them for IO. Masking shaves boot time off
  # noticeably on slower hardware.
  - systemctl mask apt-daily.service apt-daily.timer
  - systemctl mask apt-daily-upgrade.service apt-daily-upgrade.timer
  - systemctl mask fwupd.service fwupd-refresh.service fwupd-refresh.timer
  - systemctl mask motd-news.service motd-news.timer
  - systemctl mask man-db.service man-db.timer
  - systemctl mask e2scrub_all.service e2scrub_all.timer e2scrub_reap.service

  # Defensive plymouth purge. Removing plymouth from the
  # ``packages:`` list above only stops cloud-init from ADDING
  # plymouth -- it doesn't remove plymouth if the Debian cloud
  # image baseline ships it pre-installed (``cloud.url`` tracks
  # ``trixie/daily/latest`` in cijoe/configs/server-x86.toml, so
  # the baseline package set can drift between bakes). Plymouth's
  # quit/teardown emits VT100 escape sequences to /dev/console,
  # which on a server with the standard ``console=ttyS0,115200
  # console=tty0`` kernel cmdline lands as garbage like
  # ``[!p[?7h[6;32766H`` on the serial console right before agetty
  # draws the login banner. ``apt-get -y purge`` removes the
  # packages + the boot integration (initramfs hook, systemd
  # units); the trailing ``|| true`` keeps the runcmd green when
  # plymouth wasn't installed in the first place.
  - apt-get -y purge plymouth plymouth-themes plymouth-label 2>/dev/null || true
  - apt-get -y autoremove --purge 2>/dev/null || true
  # Kernel cmdline insurance: even if some plymouth-related
  # package slipped through purge (unattended-upgrades, a future
  # base-image change pulling it in via Recommends, ...),
  # ``plymouth.enable=0`` tells plymouthd to no-op at boot. Cheap
  # belt-and-braces; the dpkg-divert / systemctl-mask alternatives
  # are more invasive than this kernel arg.
  - |
    set -eu
    # Cmdline hardening (each entry is idempotently inserted into
    # GRUB_CMDLINE_LINUX_DEFAULT below):
    #   plymouth.enable=0           -- no graphical splash on the
    #                                  headless server. Defense
    #                                  against a future baseline
    #                                  pulling plymouth back in.
    #   random.trust_cpu=on
    #   random.trust_bootloader=on  -- seed CSPRNG from RDRAND /
    #                                  EFI's RngProtocol. Defaults
    #                                  are ``on`` for stock Debian
    #                                  kernels but setting them
    #                                  explicitly closes the gap
    #                                  if an operator rebuilds a
    #                                  custom kernel without
    #                                  CONFIG_RANDOM_TRUST_CPU=y.
    #                                  Without this, getrandom()
    #                                  can block early-boot
    #                                  services for many minutes
    #                                  on hardware without virtio-
    #                                  rng / RDRAND-trust.
    #   noresume                    -- skip hibernation-image probe
    #                                  on a fresh-flashed disk
    #                                  with no swap. Without it
    #                                  the kernel waits ~30s for
    #                                  the resume device to
    #                                  appear; bty-server doesn't
    #                                  hibernate so always skip.
    EXTRA="plymouth.enable=0 random.trust_cpu=on random.trust_bootloader=on noresume"
    if grep -q '^GRUB_CMDLINE_LINUX_DEFAULT=' /etc/default/grub; then
      for arg in $EXTRA; do
        # ``arg`` is either ``key=value`` or a bare flag (e.g.
        # ``noresume``). The grep token ``\b<arg>\b`` matches
        # both shapes idempotently, so re-running this block
        # never duplicates an entry.
        if ! grep -q "GRUB_CMDLINE_LINUX_DEFAULT=.*\\b${arg}\\b" /etc/default/grub; then
          sed -i "s/^GRUB_CMDLINE_LINUX_DEFAULT=\"\(.*\)\"$/GRUB_CMDLINE_LINUX_DEFAULT=\"\1 ${arg}\"/" /etc/default/grub
        fi
      done
    else
      printf '\nGRUB_CMDLINE_LINUX_DEFAULT="%s"\n' "$EXTRA" >> /etc/default/grub
    fi
    update-grub

  # Rebuild the initramfs with ``MODULES=most`` so the cooked
  # image boots cleanly on bare-metal hardware that the bake VM
  # never sees. The Debian cloud image's default
  # initramfs.conf uses ``MODULES=dep`` (just what was needed to
  # boot the bake VM on virtio), which produces a minimal initrd
  # missing real-hardware drivers like Intel I225/I226 NICs,
  # NVMe controllers with quirks, or AHCI variants. On real
  # hardware the kernel's early-init then waits 60-120s per
  # missing driver before falling through to the on-disk
  # ``/lib/modules`` set -- compounded across several devices,
  # boot stalls for many minutes on consumer mini-PCs.
  # ``MODULES=most`` packs everything initramfs-tools knows might
  # be needed for boot; ~30 MB of extra initrd, fast-probes on
  # every box.
  - |
    set -eu
    if [ -f /etc/initramfs-tools/initramfs.conf ]; then
      sed -i 's/^MODULES=.*/MODULES=most/' /etc/initramfs-tools/initramfs.conf
      grep -q '^MODULES=' /etc/initramfs-tools/initramfs.conf || \
        printf '\nMODULES=most\n' >> /etc/initramfs-tools/initramfs.conf
      update-initramfs -u
    fi

  # Enable haveged so it starts early in multi-user.target;
  # ``haveged`` ships its own systemd unit via the package's
  # postinst, but explicitly enabling here is paranoia-friendly
  # (matches the pattern used for systemd-networkd / dnsmasq).
  - systemctl enable haveged.service

  # Disable cloud-init for subsequent boots and clear its artefacts.
  # The cooked image already has its identity (bty user + default
  # password baked above), so cloud-init has nothing to do at first
  # boot - and without an attached datasource it can stall systemd's
  # multi-user.target for minutes while it polls for one. If an
  # operator wants to (re-)provision via cloud-init they can ``rm
  # /etc/cloud/cloud-init.disabled`` and attach a NoCloud ISO.
  - touch /etc/cloud/cloud-init.disabled
  - cloud-init clean --logs --seed || true
  # Also remove cloud-init's netplan output so our shipped
  # /etc/systemd/network/10-bty-default.network is the unambiguous
  # source of truth for NIC configuration after first boot. Without
  # this, netplan's cloud-init-generated YAML sticks around and the
  # next netplan apply (if any) overwrites our config.
  - rm -f /etc/netplan/50-cloud-init.yaml
  - rm -f /etc/network/interfaces.d/50-cloud-init.cfg

  # SSH host-key hygiene. openssh-server's postinst generated host
  # keys during ``apt install``; remove them now so the cooked
  # image does NOT carry per-bake keys that every operator's
  # downloaded appliance would otherwise share. ``bty-ssh-host-
  # keys.service`` (enabled above) regenerates a unique set on
  # first boot of each cooked instance, gated on the ed25519 key
  # being absent.
  - rm -f /etc/ssh/ssh_host_*

  # Trim apt + pip caches to keep the image small.
  - apt-get clean
  - rm -rf /var/lib/apt/lists/*
  - rm -rf /root/.cache /home/*/.cache

power_state:
  mode: poweroff
  timeout: 30
  message: "bty server image baked - powering off the build VM"

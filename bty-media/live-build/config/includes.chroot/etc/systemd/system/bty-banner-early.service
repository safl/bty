[Unit]
Description=bty boot banner -- step 1 of 3 (early)
Documentation=https://github.com/safl/bty
# Ordered as early as possible: just after the kernel hands
# off to systemd, before sysinit.target completes. The
# operator's first visible bty identity marker.
DefaultDependencies=no
Before=sysinit.target
# Don't block on anything; this is a print statement.
RefuseManualStop=yes

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/bty-boot-banner early
StandardOutput=journal+console
StandardError=journal+console
RemainAfterExit=yes

[Install]
WantedBy=sysinit.target

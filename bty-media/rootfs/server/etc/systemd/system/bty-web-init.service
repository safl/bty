[Unit]
Description=bty-web first-boot initialisation (state dir, /etc/default/bty-web, login banner)
Documentation=https://github.com/safl/bty
# Skip on every boot after the first - the env file has been written
# and the operator may have edited it.
ConditionPathExists=!/etc/default/bty-web
Before=bty-web.service
DefaultDependencies=no
After=local-fs.target

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/bty-web-init
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target

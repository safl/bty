[Unit]
Description=bty-web HTTP server
Documentation=https://github.com/safl/bty
Requires=bty-web-init.service
After=network-online.target bty-web-init.service
Wants=network-online.target

[Service]
Type=exec
EnvironmentFile=/etc/default/bty-web
ExecStart=/opt/bty/venv/bin/bty-web
Restart=on-failure
RestartSec=5
User=bty
Group=bty
ProtectSystem=full
ProtectHome=true
# bty-web's "Activate PXE" / "Deactivate PXE" buttons shell out
# to sudo'd helpers ``/usr/local/sbin/bty-web-activate-pxe`` and
# ``/usr/local/sbin/bty-web-deactivate-pxe`` which write or remove
# ``/etc/dnsmasq.d/bty-pxe-active.conf``. ``ProtectSystem=full``
# bind-mounts ``/etc`` as read-only into this unit's namespace,
# and ``sudo`` elevates UID but NOT the mount namespace -- so
# either helper, even as root, would see ``/etc`` as read-only and
# fail with ``mktemp: ... Read-only file system`` (activate) or
# ``rm: ... Read-only file system`` (deactivate). Punch a single
# read-write hole for the dnsmasq config dir; everything else
# in /etc stays protected.
ReadWritePaths=/etc/dnsmasq.d
# Intentionally NOT setting NoNewPrivileges=true: bty-web's
# /ui/login authenticates via PAM (pamela -> libpam -> pam_unix ->
# setgid unix_chkpwd to read /etc/shadow). NoNewPrivileges blocks
# the setgid privilege gain that pam_unix needs, so every login
# would fail "authentication failure" with the correct password.
# The bty user is already unprivileged; the additional defense-in-
# depth NNP would offer is small, and breaks PAM.

[Install]
WantedBy=multi-user.target

# Default networking for the bty server appliance.
#
# DHCP any predictably-named ethernet interface (Debian 13 / systemd
# 257 renders QEMU virtio NICs as ``ens<slot>`` and physical NICs as
# ``eno*`` / ``enp*``). The first interface to get a lease becomes
# bty-web's reachable address; additional NICs are still managed but
# are NOT required to be "online" before ``network-online.target``,
# so a homelab box with one cable plugged in (or a test VM with
# only its mgmt link wired) doesn't stall the boot for two minutes
# while ``systemd-networkd-wait-online`` polls a dead NIC.
#
# Operators who want a static IP / a specific NIC to be the PXE
# segment / etc. drop their own ``.network`` file with a more
# specific [Match] - systemd-networkd uses the lexically-first match
# and ours is intentionally low-priority (Match wildcards lose to
# any explicit Name=).

[Match]
Name=en*

[Network]
DHCP=yes

[DHCP]
# Standard DHCP client behaviour against the operator's LAN
# DHCP server. bty does not run any DHCP role itself; the
# appliance lease is just a normal client lease.
UseDNS=yes
UseNTP=yes
RouteMetric=100

[Link]
RequiredForOnline=routable:degraded

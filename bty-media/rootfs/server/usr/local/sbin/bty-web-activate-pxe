#!/bin/sh
# bty-web PXE activation helper.
#
# Invoked by the ``bty`` service user via the entry in
# ``/etc/sudoers.d/bty-web``. Writes a dnsmasq config to
# ``/etc/dnsmasq.d/bty-pxe-active.conf`` and restarts
# ``dnsmasq.service`` so the new config takes effect.
#
# Two modes:
#
#   proxy   Proxy-DHCP. There is already another DHCP server on
#           the segment (typical LAN). dnsmasq only answers PXE
#           queries; existing DHCP keeps handing out IPs.
#
#   full    bty-server is the only DHCP server on the segment
#           (homelab / isolated CI net). dnsmasq runs full DHCP
#           and answers PXE queries. Pick this when there's no
#           other DHCP server to layer onto.
#
# The shipped ``/etc/dnsmasq.d/bty-pxe.conf`` keeps everything
# commented as documentation; this active config goes in a separate
# file so the original stays as the canonical example. Removing
# the active file + ``systemctl restart dnsmasq`` deactivates PXE
# again.
#
# Args:
#   $1  mode (``proxy`` or ``full``)
#   $2  network interface (e.g. ``eth0``, ``ens18``)
#   $3  subnet network address (e.g. ``192.168.1.0``)
#   $4  in full mode only: range start (e.g. ``192.168.99.50``)
#   $5  in full mode only: range end (e.g. ``192.168.99.150``)
#   $6  in full mode only: netmask (e.g. ``255.255.255.0``)

set -eu

usage() {
    printf 'usage:\n' >&2
    printf '  %s proxy <interface> <subnet>\n' "$0" >&2
    printf '  %s full  <interface> <subnet> <range-lo> <range-hi> <netmask>\n' "$0" >&2
    exit 64
}

[ $# -ge 3 ] || usage

MODE=$1
IFACE=$2
SUBNET=$3

case "$MODE" in
    proxy) [ $# -eq 3 ] || usage ;;
    full)  [ $# -eq 6 ] || usage; RANGE_LO=$4; RANGE_HI=$5; NETMASK=$6 ;;
    *)     usage ;;
esac

# Validate inputs (defence in depth - the caller bty-web also
# validates, but this script runs as root).
case "$IFACE" in
    "" | *[!a-zA-Z0-9_-]*) printf 'bad interface name: %s\n' "$IFACE" >&2; exit 64 ;;
esac
case "$SUBNET" in
    "" | *[!0-9.]*) printf 'bad subnet: %s\n' "$SUBNET" >&2; exit 64 ;;
esac
if [ "$MODE" = "full" ]; then
    case "$RANGE_LO" in "" | *[!0-9.]*) printf 'bad range-lo\n' >&2; exit 64 ;; esac
    case "$RANGE_HI" in "" | *[!0-9.]*) printf 'bad range-hi\n' >&2; exit 64 ;; esac
    case "$NETMASK"  in "" | *[!0-9.]*) printf 'bad netmask\n'  >&2; exit 64 ;; esac
fi

ACTIVE=/etc/dnsmasq.d/bty-pxe-active.conf
TMP=$(mktemp)
trap 'rm -f "$TMP"' EXIT

# ``bind-dynamic`` (instead of bind-interfaces) tolerates the
# interface coming up after dnsmasq starts - relevant when a
# systemd-networkd unit assigns the static IP after dnsmasq.service
# has already started its bind sequence.
{
    printf '# Generated by bty-web-activate-pxe (mode=%s).\n' "$MODE"
    printf '# Removing this file and restarting dnsmasq deactivates the chain.\n\n'
    printf 'bind-dynamic\n'
    printf 'interface=%s\n' "$IFACE"
    if [ "$MODE" = "proxy" ]; then
        printf 'dhcp-range=%s,proxy\n' "$SUBNET"
    else
        printf 'dhcp-range=%s,%s,%s,1h\n' "$RANGE_LO" "$RANGE_HI" "$NETMASK"
    fi
    cat <<'EOF'

dhcp-match=set:bios,option:client-arch,0
dhcp-match=set:efi,option:client-arch,7
dhcp-match=set:efi,option:client-arch,9
dhcp-userclass=set:ipxe,iPXE

dhcp-boot=tag:!ipxe,tag:bios,undionly.kpxe
dhcp-boot=tag:!ipxe,tag:efi,ipxe.efi
dhcp-boot=tag:ipxe,http://${next-server}:8080/pxe-bootstrap.ipxe
EOF
} > "$TMP"

chown root:root "$TMP"
chmod 0644 "$TMP"
mv "$TMP" "$ACTIVE"
trap - EXIT

systemctl restart dnsmasq.service

if [ "$MODE" = "proxy" ]; then
    printf 'PXE activated on %s (proxy on %s)\n' "$IFACE" "$SUBNET"
else
    printf 'PXE activated on %s (full DHCP %s-%s/%s)\n' \
        "$IFACE" "$RANGE_LO" "$RANGE_HI" "$NETMASK"
fi

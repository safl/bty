#!/bin/sh
# bty-web PXE deactivation helper.
#
# Invoked by the ``bty`` service user via the entry in
# ``/etc/sudoers.d/bty-web``. Stops the ``bty-pxe-proxy.service``
# and removes the env file at ``/etc/default/bty-pxe-proxy``.
#
# Idempotent: a missing env file / stopped service is treated as
# success ("already deactivated") so the operator can click
# Deactivate from a clean state without seeing an error.
#
# Pairs with ``bty-web-activate-pxe``. We also clean up any
# historical dnsmasq-proxy-DHCP file at
# /etc/dnsmasq.d/bty-pxe-active.conf so an appliance upgraded in
# place settles to one source of truth.

set -eu

ACTIVE=/etc/default/bty-pxe-proxy

# Stop both PXE-stack daemons. We don't disable them: ``disable``
# would need /etc/systemd/system writable (bty-web runs under
# ProtectSystem=full + this script inherits that namespace), and
# we don't actually need them disabled -- both units have
# ``ConditionPathExists=/etc/default/bty-pxe-proxy`` so the
# enabled-but-no-env-file state is "armed but inactive" on every
# boot, which is exactly what "deactivated" means here.
systemctl stop bty-pxe-proxy.service bty-tftp.service 2>/dev/null || true

removed_something=0
if [ -f "$ACTIVE" ]; then
    rm -f "$ACTIVE"
    removed_something=1
fi

# Cleanup of any historical dnsmasq-proxy-DHCP file.
if [ -f /etc/dnsmasq.d/bty-pxe-active.conf ]; then
    rm -f /etc/dnsmasq.d/bty-pxe-active.conf
    systemctl restart dnsmasq.service
    removed_something=1
fi

if [ "$removed_something" = "1" ]; then
    printf 'PXE deactivated (stopped bty-pxe-proxy.service, cleared %s)\n' "$ACTIVE"
else
    printf 'PXE already inactive (no %s)\n' "$ACTIVE"
fi

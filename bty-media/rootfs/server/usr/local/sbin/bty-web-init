#!/bin/sh
# bty-web first-boot initialisation
#
# - Creates the state directory tree.
# - Writes /etc/default/bty-web with runtime config (state dir, image
#   root, boot dir, listen host/port).
# - Generates a random initial password for the bty service user so
#   the operator has a working PAM credential the moment first boot
#   completes - no manual ``sudo passwd bty`` step. The password is
#   shown on /etc/issue (visible on the console banner) AND written
#   to /var/lib/bty/initial-password (root-readable only) so the
#   operator can ``sudo cat`` it from an SSH session too. Operators
#   rotate later with ``sudo passwd bty`` like any other Linux user.
#
# Idempotent: ConditionPathExists=!/etc/default/bty-web on the
# associated systemd unit means this script only runs on first boot
# (or after the operator deliberately deletes the file).

set -eu

install -d -o bty -g bty -m 0750 /var/lib/bty
install -d -o bty -g bty -m 0750 /var/lib/bty/images
install -d -o bty -g bty -m 0750 /var/lib/bty/boot
install -d -o bty -g bty -m 0750 /var/lib/bty/workflows
# Operator drops the SSH key for online cijoe at /var/lib/bty/keys/
# id_ed25519 (milestone 15 phase 1 - key generation lands later).
install -d -o bty -g bty -m 0700 /var/lib/bty/keys

# Generate the initial password and apply it - but only if the bty
# user doesn't already have one set. This lets cloud-init (or an
# operator using ``chpasswd`` from a kickstart-style first-boot
# script) pre-seed a known password without bty-web-init clobbering
# it. ``passwd -S`` prints "bty P ..." when a password is set,
# "bty L ..." when locked, "bty NP ..." when unset.
PASSWORD_STATE=$(passwd -S bty 2>/dev/null | awk '{print $2}')
if [ "${PASSWORD_STATE:-NP}" = "P" ]; then
    echo "bty-web-init: bty already has a password (preserving it)"
else
    # ``token_urlsafe(16)`` yields ~22 URL-safe chars - long enough
    # that a brute-force over the bty-web HTTP login endpoint isn't
    # worth attempting; short enough to type if the operator captures
    # it from the console.
    PASSWORD=$(python3 -c 'import secrets; print(secrets.token_urlsafe(16))')
    echo "bty:${PASSWORD}" | chpasswd

    # /var/lib/bty/initial-password: 0600 root, so ``sudo cat`` it
    # from any account with sudo. Removing this file is optional -
    # it's only the *initial* credential; ``passwd bty`` doesn't
    # update it and it stops being authoritative the moment the
    # operator rotates.
    umask 077
    printf '%s\n' "${PASSWORD}" > /var/lib/bty/initial-password
    chown root:root /var/lib/bty/initial-password
    chmod 0600 /var/lib/bty/initial-password
fi

cat > /etc/default/bty-web <<'EOF'
# Generated by bty-web-init on first boot. bty-web reads its config
# from this file via systemd's EnvironmentFile=. Auth is OS-PAM
# against the bty service user; rotate the credential with
# ``sudo passwd bty``.
BTY_STATE_DIR=/var/lib/bty
BTY_IMAGE_ROOT=/var/lib/bty/images
BTY_BOOT_DIR=/var/lib/bty/boot
BTY_WEB_HOST=0.0.0.0
BTY_WEB_PORT=8080
EOF
chown root:bty /etc/default/bty-web
chmod 0640 /etc/default/bty-web

# Rewrite /etc/issue with the URL and (when one was generated above)
# the initial password. \4 and \n \l are agetty escapes resolved at
# login time, so the IP shown is whatever the box has when the
# prompt is rendered (DHCP-friendly). When cloud-init or an operator
# pre-seeded the password, the issue text just points at
# ``passwd bty`` for rotation rather than printing a secret nobody
# generated.
if [ -n "${PASSWORD:-}" ]; then
    cat > /etc/issue <<EOF

======================================================================
  bty server appliance

  Browser UI:        http://\\4:8080/ui
  Initial password:  ${PASSWORD}
                     (also at /var/lib/bty/initial-password, root-only)
  Account:           bty

  Rotate the credential with ``sudo passwd bty``.
======================================================================

Debian \\n \\l
EOF
else
    cat > /etc/issue <<'EOF'

======================================================================
  bty server appliance

  Browser UI:    http://\4:8080/ui
  Account:       bty (password set externally)

  Rotate the credential with ``sudo passwd bty``.
======================================================================

Debian \n \l
EOF
fi

#!ipxe
# bty network-flash for {{ mac }}
#   bty_image_ref:      {{ flash_key }}
#   target_disk_serial: {{ target_disk_serial }}
#
# Chains into the bty live env. The live env's
# bty-on-tty1.service exec's ``bty --server X --mac Y``;
# ``bty`` then GETs ``<server>/pxe/<mac>/plan`` and dispatches
# on the JSON response (mode=auto -> flash without prompts,
# mode=interactive -> wizard on tty1, mode=local -> exit, let
# firmware boot).
#
# The kernel cmdline only carries ``bty.server`` + ``bty.mac``;
# every other knob (image URL, target disk serial, etc.) comes
# from the plan endpoint. Keeps the iPXE chain template-agnostic
# and the operator-facing cmdline minimal -- one source of truth
# (the machine record), one place that decides what to do (the
# plan endpoint).

set bty-base http://{{ host }}
# fetch= tells live-boot's initramfs to download the squashfs over
# HTTP and mount it as the rootfs (no local disk needed).
# console=tty0 console=ttyS0,115200 sends kernel + systemd messages
# to both the screen and the serial port. The serial mirror is
# essential for headless bare-metal flashing (operator watches via
# IPMI / serial console) and for the PXE chain test.
# Transparency: NO ``quiet`` -- bty wants the full kernel + systemd
# boot stream visible. See ipxe_tui.j2 + live-build/auto/config for
# the matching rationale.
# The /boot artifact URLs carry ``?mac={{ mac }}``. The server already
# knows this MAC (it rendered this template for it), so embedding it is
# free; the matching ``GET /boot/...?mac=`` is positive proof THIS box
# booted the flasher. bty-web uses that to arm a one-shot sanboot of
# the just-flashed disk on the next PXE contact, so bty-flash-always
# boots the image once instead of reflashing in a loop under PXE-first
# firmware. The query string is ignored when serving the file bytes.
kernel ${bty-base}/boot/bty-netboot-x86_64.vmlinuz?mac={{ mac }} boot=live fetch=${bty-base}/boot/bty-netboot-x86_64.squashfs?mac={{ mac }} components console=tty0 console=ttyS0,115200 plymouth.enable=0 modprobe.blacklist=nouveau nouveau.modeset=0 bty.server=${bty-base} bty.mac={{ mac }}
initrd ${bty-base}/boot/bty-netboot-x86_64.initrd?mac={{ mac }}
boot

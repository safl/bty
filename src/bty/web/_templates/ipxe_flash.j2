#!ipxe
# bty network-flash for {{ mac }}
#   bty_image_ref:      {{ flash_key }}
#   target_disk_serial: {{ target_disk_serial }}
#
# Chains into the bty live env. The live env's
# bty-on-tty1.service exec's ``bty --server X --mac Y``;
# ``bty`` then GETs ``<server>/pxe/<mac>/plan`` and dispatches
# on the JSON response (mode=flash -> flash without prompts,
# mode=interactive -> wizard on tty1, mode=exit -> exit, let
# firmware boot).
#
# The kernel cmdline only carries ``bty.server`` + ``bty.mac``;
# every other knob (image URL, target disk serial, etc.) comes
# from the plan endpoint. Keeps the iPXE chain template-agnostic
# and the operator-facing cmdline minimal -- one source of truth
# (the machine record), one place that decides what to do (the
# plan endpoint).

set bty-base http://{{ host }}
# fetch= tells live-boot's initramfs to download the squashfs over
# HTTP and mount it as the rootfs (no local disk needed).
# console=tty0 console=ttyS1,115200 console=ttyS0,115200 sends
# kernel messages to the framebuffer AND to BOTH first UARTs. The
# serial mirror is essential for headless bare-metal flashing
# (operator watches via IPMI / serial console) and for the PXE
# chain test. Listing both ttyS0 and ttyS1 covers the two default
# BMC SoL bridges in the field: Dell / iLO usually bridge COM1
# (ttyS0), Supermicro / older Intel boards typically bridge COM2
# (ttyS1) -- on the latter the BMC SoL UI sometimes exposes only
# "COM1 or SOL" with no working COM1 wiring, so SoL is wired to
# the BMC's dedicated UART (Linux sees it as ttyS1). Writing to
# both gets the kernel output onto whichever UART the BMC
# happens to be bridging without per-vendor BIOS twiddling. The
# kernel writes to every registered ``console=`` regardless of
# order; only userspace ``/dev/console`` (init banners, bty's
# stdout) follows the last-listed rule. ttyS0 is LAST on purpose
# so that ``/dev/console`` lands on the UART the cijoe PXE chain
# test attaches to (a ``file:`` chardev on COM1); a future edit
# that reorders these must also re-verify the chain test.
# ``earlyprintk=ttyS0,115200`` forces the kernel's own
# console-registration messages onto ttyS0 BEFORE the printk
# console-list is reshuffled, so a future order-related regression
# leaves a diagnostic trail in the captured serial log even if
# something later goes wrong.
# Transparency: NO ``quiet`` -- bty wants the full kernel + systemd
# boot stream visible. See ipxe_tui.j2 + live-build/auto/config for
# the matching rationale.
# The kernel + initrd URLs (fetched by iPXE) carry ``?mac={{ mac }}``.
# The server already knows this MAC (it rendered this template for it),
# so it's free; the matching ``GET /boot/...?mac=`` is positive proof
# THIS box booted the flasher. bty-web arms a one-shot sanboot of the
# just-flashed disk on the next PXE contact off that, so
# bty-flash-always boots the image once instead of reflashing in a loop
# under PXE-first firmware. The query is ignored when serving the bytes.
# The squashfs ``fetch=`` URL is DELIBERATELY NOT tagged: live-boot's
# initramfs derives a local filename from that URL and chokes on the
# ``?`` / ``:`` (it aborts with "Unable to find a live file system on
# the network"). The kernel/initrd fetch already armed the bit, so the
# squashfs tag would be redundant anyway.
# ``systemd.gpt_auto=0`` disables systemd-gpt-auto-generator, which
# would otherwise auto-mount the flash TARGET's existing partitions
# (ESP / root / home, swapon) by their well-known GPT type GUIDs -- the
# live env has no business touching the disk it's about to overwrite.
# Without it every reflash (especially bty-flash-always) boots with the
# target already mounted; bty unmounts as a backstop, but not mounting
# it in the first place is the correct fix. Served by bty-web, so this
# takes effect on the next PXE boot with no media rebake.
# ``modprobe.blacklist=nouveau,rndis_host``: nouveau is blacklisted
# because the open-source Nvidia driver wedges on several iGPUs in the
# flasher's framebuffer-only context (MS-01, GMKTec G5). ``rndis_host``
# is blacklisted because Supermicro / Aspeed BMCs expose a "USB Virtual
# NIC" gadget that presents over RNDIS; live-boot sees it as a connected
# Ethernet, picks it (sorts before ``eno*``), tries to DHCP+fetch the
# squashfs over the BMC's internal USB network (which can't reach the
# bty server), and panics with ``Unable to find a live file system on
# the network``. Real USB-Ethernet dongles (Realtek r8152, ASIX
# AX88179) use chip-specific drivers and are unaffected.
kernel ${bty-base}/boot/bty-netboot-pc-x86_64-v{{ bty_version }}.vmlinuz?mac={{ mac }} boot=live fetch=${bty-base}/boot/bty-netboot-pc-x86_64-v{{ bty_version }}.squashfs components console=tty0 console=ttyS1,115200 console=ttyS0,115200 earlyprintk=ttyS0,115200 plymouth.enable=0 modprobe.blacklist=nouveau,rndis_host nouveau.modeset=0 systemd.gpt_auto=0 bty.server=${bty-base} bty.mac={{ mac }}
initrd ${bty-base}/boot/bty-netboot-pc-x86_64-v{{ bty_version }}.initrd?mac={{ mac }}
boot

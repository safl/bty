#!ipxe
# bty network-flash for {{ mac }}
#   bty_image_ref:  {{ machine.bty_image_ref }}
#   disk_image_sha: {{ flash_sha }}
#
# Chains into the bty live env. The live env's bty-flash-on-boot
# service reads bty.* from /proc/cmdline, downloads the image,
# runs ``bty flash --yes``, signals completion, and reboots.

set bty-base http://{{ host }}
# fetch= tells live-boot's initramfs to download the squashfs over
# HTTP and mount it as the rootfs (no local disk needed).
# console=tty0 console=ttyS0,115200 sends kernel + systemd messages
# to both the screen and the serial port. The serial mirror is
# essential for headless bare-metal flashing (operator watches via
# IPMI / serial console) and for the PXE chain test.
#
# bty.image_url is content-addressed: ``/images/<disk_image_sha>/<name>``
# is resolved server-side via the catalog row that machines bind to
# (``machines.bty_image_ref`` -> ``catalog_entries.disk_image_sha``).
# The trailing ``/<name>`` is decorative -- the disk SHA binds the
# bytes; the name preserves format-by-extension on the live-env side
# (``bty.flash.probe_image_url`` keys off the URL filename).
kernel ${bty-base}/boot/bty-netboot-x86_64.vmlinuz boot=live fetch=${bty-base}/boot/bty-netboot-x86_64.squashfs components quiet console=tty0 console=ttyS0,115200 bty.server=${bty-base} bty.mac={{ mac }} bty.image_url=${bty-base}/images/{{ flash_sha }}/{{ image_name }}
initrd ${bty-base}/boot/bty-netboot-x86_64.initrd
boot

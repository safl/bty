#!ipxe
# bty network-flash for {{ mac }}
#   bty_image_ref:      {{ flash_key }}
#   target_disk_serial: {{ target_disk_serial }}
#
# Chains into the bty live env. The live env's
# bty-on-tty1.service exec's ``bty --server X --mac Y``;
# ``bty`` then GETs ``<server>/pxe/<mac>/plan`` and dispatches
# on the JSON response (mode=flash -> flash without prompts,
# mode=interactive -> wizard on tty1, mode=exit -> exit, let
# firmware boot).
#
# The kernel cmdline only carries ``bty.server`` + ``bty.mac``;
# every other knob (image URL, target disk serial, etc.) comes
# from the plan endpoint. Keeps the iPXE chain template-agnostic
# and the operator-facing cmdline minimal -- one source of truth
# (the machine record), one place that decides what to do (the
# plan endpoint).

set bty-base http://{{ host }}
# fetch= tells live-boot's initramfs to download the squashfs over
# HTTP and mount it as the rootfs (no local disk needed).
# console=tty0 console=ttyS0,115200 sends kernel + systemd messages
# to both the screen and the serial port. The serial mirror is
# essential for headless bare-metal flashing (operator watches via
# IPMI / serial console) and for the PXE chain test.
# Transparency: NO ``quiet`` -- bty wants the full kernel + systemd
# boot stream visible. See ipxe_tui.j2 + live-build/auto/config for
# the matching rationale.
# The kernel + initrd URLs (fetched by iPXE) carry ``?mac={{ mac }}``.
# The server already knows this MAC (it rendered this template for it),
# so it's free; the matching ``GET /boot/...?mac=`` is positive proof
# THIS box booted the flasher. bty-web arms a one-shot sanboot of the
# just-flashed disk on the next PXE contact off that, so
# bty-flash-always boots the image once instead of reflashing in a loop
# under PXE-first firmware. The query is ignored when serving the bytes.
# The squashfs ``fetch=`` URL is DELIBERATELY NOT tagged: live-boot's
# initramfs derives a local filename from that URL and chokes on the
# ``?`` / ``:`` (it aborts with "Unable to find a live file system on
# the network"). The kernel/initrd fetch already armed the bit, so the
# squashfs tag would be redundant anyway.
# ``systemd.gpt_auto=0`` disables systemd-gpt-auto-generator, which
# would otherwise auto-mount the flash TARGET's existing partitions
# (ESP / root / home, swapon) by their well-known GPT type GUIDs -- the
# live env has no business touching the disk it's about to overwrite.
# Without it every reflash (especially bty-flash-always) boots with the
# target already mounted; bty unmounts as a backstop, but not mounting
# it in the first place is the correct fix. Served by bty-web, so this
# takes effect on the next PXE boot with no media rebake.
kernel ${bty-base}/boot/bty-netboot-pc-x86_64-v{{ bty_version }}.vmlinuz?mac={{ mac }} boot=live fetch=${bty-base}/boot/bty-netboot-pc-x86_64-v{{ bty_version }}.squashfs components console=tty0 console=ttyS0,115200 plymouth.enable=0 modprobe.blacklist=nouveau nouveau.modeset=0 systemd.gpt_auto=0 bty.server=${bty-base} bty.mac={{ mac }}
initrd ${bty-base}/boot/bty-netboot-pc-x86_64-v{{ bty_version }}.initrd?mac={{ mac }}
boot

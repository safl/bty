#!ipxe
# bty-web - per-MAC iPXE config for {{ mac }}
# Assignment:
#   image (ref):       {{ machine.image_sha256 or "(none)" }}
#   provisioning mode: {{ machine.provisioning_mode }}
#   hostname:          {{ machine.hostname or "(none)" }}
#
# This template is rendered when the machine has an image assigned
# but ``boot_policy=local`` - the machine has been provisioned at
# some point and now boots normally from its disk. ``exit`` returns
# control to the PXE ROM, which falls through to the next boot
# device (typically the local disk).

echo bty: {{ mac }} boot_policy=local sha256={{ (machine.image_sha256 or "none")[:12] }}..., returning to local boot
sleep 1
exit

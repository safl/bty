#!ipxe
# bty-web - per-MAC iPXE config for {{ mac }}
# Assignment:
#   image (ref):       {{ machine.bty_image_ref or "(none)" }}
#   hostname:          {{ machine.hostname or "(none)" }}
#   boot_mode:       {{ machine.boot_mode }}
#
# This template is the exit-to-firmware fallback, rendered for a
# flash policy (``bty-flash-always`` / ``bty-flash-once``) that can't
# be auto-resolved -- no ``target_disk_serial`` picked, or an orphaned
# ``bty_image_ref`` (no catalog row resolves the ref; surfaced as a
# ``pxe.flash.no_target_disk`` / ``pxe.flash.orphan_ref`` event in
# /ui/events). ``exit`` returns control to the PXE ROM, which falls
# through to the next boot device (typically the local disk).

echo bty: {{ mac }} boot_mode={{ machine.boot_mode }} ref={{ (machine.bty_image_ref or "none")[:12] }}..., returning to local boot
sleep 1
exit

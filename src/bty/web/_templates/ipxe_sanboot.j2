#!ipxe
# bty-web - per-MAC iPXE config for {{ mac }} (boot_mode={{ policy }})
# Assignment:
#   image (ref):       {{ machine.bty_image_ref or "(none)" }}
#   labels:            {{ (machine.labels | join(", ")) or "(none)" }}
#   boot_mode:       {{ policy }}
#   sanboot drive:     {{ drive }}
#
# This boots the local disk. It's used directly by
# ``boot_mode=ipxe-exit`` (the boot-mode value renamed from
# ``sanboot`` in v0.25.0; the underlying iPXE verb below still
# reads ``sanboot`` on legacy BIOS), and also as the post-step
# boot for ``bty-inventory`` (after disks are reported) and
# ``bty-flash-always`` (after the one-shot flash) -- so the
# policy is templated, not hardcoded.
#
# Firmware split (this is the important part):
#   * UEFI -- there is NO BIOS INT13 drive map, so ``sanboot --drive``
#     cannot see the local disk and always fails. The correct UEFI way
#     to boot the installed OS is to hand control back to the firmware
#     boot order via ``exit``; the firmware then boots the disk's EFI
#     loader (the next entry after network boot). Modern hardware is
#     UEFI, so this is the common path.
#   * Legacy BIOS -- ``sanboot --no-describe --drive {{ drive }}`` boots
#     the BIOS drive directly (0x80 = first disk), independent of the
#     BIOS boot order, with ``|| exit`` as the firmware-order fallback.
#     ``--drive`` is a BIOS drive number, NOT the Linux serial the flash
#     step matches on, so it's distinct from ``target_disk_serial``.
#
# A successful local boot means iPXE never returns; an ``exit`` hands
# back to the embedded script (ipxe-embed.ipxe), which itself exits to
# the firmware boot order rather than dropping to a shell.

echo bty: {{ mac }} boot_mode={{ policy }}, booting local disk (platform=${platform})
sleep 1
iseq ${platform} efi && exit || sanboot --no-describe --drive {{ drive }} || exit

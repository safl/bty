#!ipxe
# bty network-flash for {{ mac }} - interactive wizard mode (boot_mode=bty-tui)
#
# ``boot_mode=bty-tui``: chain into the bty live env. The live env's
# bty-on-tty1 service exec's ``bty --server X --mac Y``;
# ``bty`` GETs ``<server>/pxe/<mac>/plan`` and dispatches on the
# JSON response. For ``boot_mode=bty-tui`` the plan endpoint returns
# ``{"mode": "interactive", "catalog": ...}`` and ``bty`` drops the
# operator into the wizard with the server's catalog pre-loaded.
#
# This is the default for unknown MACs that PXE-boot through the
# server: anyone on the segment lands at "bty-on-a-USB-but-over-the-
# network" without prior configuration.
#
# The kernel cmdline only carries ``bty.server`` + ``bty.mac`` --
# every other knob (image URL, target disk, catalog) comes from
# the plan endpoint. Keeps the iPXE chain template-agnostic and
# the operator-facing cmdline minimal.

set bty-base http://{{ host }}
# Transparency: NO ``quiet`` -- bty wants the full kernel + systemd
# boot stream visible. A wedge between two ``[ OK ] Started X`` lines
# is immediately diagnostic. Same reason plymouth was retired
# (v0.22.1); see live-build/auto/config for the matching USB-ISO
# cmdline. The screen otherwise jumps from ``[ INFO ] BTY step 1`` to
# ``step 2`` to ``step 3`` with NOTHING between the banners, leaving
# the operator with no insight into what systemd is doing.
# The kernel + initrd URLs (iPXE-fetched) carry ``?mac={{ mac }}`` so a
# fetch is proof this box booted the live env. ``bty-inventory`` uses
# that to arm a one-shot ipxe-exit chain of the disk on the next PXE contact
# (the bit is policy-gated server-side, so it's a no-op for plain
# ``bty-tui``). The squashfs ``fetch=`` URL is DELIBERATELY NOT tagged:
# live-boot's initramfs can't fetch a URL with a ``?mac=`` query (it
# aborts with "Unable to find a live file system on the network"); the
# kernel/initrd fetch already armed the bit.
# ``systemd.gpt_auto=0``: don't auto-mount the target disk's existing
# partitions (see ipxe_flash.j2 for the rationale). The stick's own
# BTY_IMAGES catalog is mounted by its explicit label-gated mount unit,
# not by gpt-auto, so it's unaffected.
kernel ${bty-base}/boot/bty-netboot-pc-x86_64-v{{ bty_version }}.vmlinuz?mac={{ mac }} boot=live fetch=${bty-base}/boot/bty-netboot-pc-x86_64-v{{ bty_version }}.squashfs components console=tty0 console=ttyS1,115200 console=ttyS0,115200 earlyprintk=ttyS0,115200 plymouth.enable=0 modprobe.blacklist=nouveau,rndis_host nouveau.modeset=0 systemd.gpt_auto=0 bty.server=${bty-base} bty.mac={{ mac }}
initrd ${bty-base}/boot/bty-netboot-pc-x86_64-v{{ bty_version }}.initrd?mac={{ mac }}
boot

#!ipxe
# bty ramboot for {{ mac }}
#   image_ref:    {{ image_ref }}
#   export_name:  {{ export_name }}
#   nbd_endpoint: tcp://{{ nbd_host }}:{{ nbd_port }}
#   overlay_size: {{ overlay_size }}
#   kernel path:  {% if netboot_ready %}image-native (nbdmux artifact){% else %}bty-media ramboot-init (fallback){% endif %}
#
# Two kernel-load paths, picked at render time by ``netboot_ready``:
#
# 1. ``netboot_ready = True``  -- the sibling nosi netboot bundle
#    (kernel + initrd extracted from the image itself) is present in
#    nbdmux's artifacts dir, so bty points the iPXE kernel + initrd
#    lines at ``<nbdmux>/artifacts/<export>/{vmlinuz,initrd}``. The
#    image boots with its OWN kernel, so ``uname -r`` inside the
#    rambooted guest matches ``/lib/modules/`` on the same rootfs and
#    every driver/module the image ships with resolves.
#
# 2. ``netboot_ready = False`` -- either the catalog entry has no
#    ``netboot_ref`` (legacy or third-party image without a matching
#    bundle), the sibling bundle entry isn't yet downloaded on
#    withcache, or nbdmux is on <0.9 (pre-artifact-stage). Fall back
#    to the bty-media-baked ramboot-init variant (Debian 6.12 kernel
#    + slim initrd). Works everywhere but ``uname -r`` inside the
#    guest doesn't match the image's ``/lib/modules/`` tree, so
#    driver modules from the image's kernel package can't load.
#
# Either way the initramfs sources ``/etc/initramfs-tools/scripts/ramboot``,
# reads ``bty.*`` from /proc/cmdline, nbd-client connects to nbdmux,
# overlays a tmpfs onto the catalog image's root partition, and
# pivot_roots into the running OS. The disk is never touched.
#
# Unlike the bty-flash chain, ramboot does NOT reach bty's userspace
# in the live env -- the initramfs pivots away before /sbin/init.
# So nothing here POSTs back to /pxe/{mac}/done; the best-effort
# status POST from the initramfs (status=ramboot.up) is the only
# completion signal. The disk image's own boot sequence runs as if
# the box had booted normally.

set bty-base http://{{ host }}
{% if netboot_ready %}
set nbdmux-base {{ nbdmux_base }}
{% endif %}
# The kernel + initrd URLs (fetched by iPXE) carry ``?mac={{ mac }}``.
# Same as the flash chain: positive proof THIS box booted ramboot.
# bty-web logs the boot fetch as a ramboot.kernel_fetched event so
# the operator timeline shows the chain firing before the
# in-initrd status POST lands.
#
# Console: same set as the flash chain (tty0 + ttyS1 + ttyS0,
# earlyprintk on ttyS0). The matching rationale in ipxe_flash.j2
# applies verbatim; ramboot pivots to the catalog image's own init
# which has its own console policy, but kernel boot + initramfs
# messages need to reach the operator regardless.
#
# Modprobe blacklist: same set as the flash chain, same reasons
# (nouveau wedges on iGPUs; rndis_host steals the network on
# Supermicro / Aspeed BMCs).
#
# bty.* params consumed by the ramboot driver in the initramfs:
#   bty.nbd          = ``tcp://<host>:<port>``, the nbd-server
#   bty.image        = the named export to attach
#   bty.overlay_size = tmpfs size for the overlay
#   bty.server       = where to POST status (best-effort)
#   bty.mac          = which machine to POST status for
# ``extra_cmdline`` (settings > ramboot > "Extra kernel cmdline") is
# appended verbatim -- empty by default, populate for debugging
# (``init=/bin/sh`` = busybox shell after pivot;
# ``systemd.debug-shell=1`` = systemd's debug shell on tty9;
# ``break=bottom`` = break in the initramfs before pivot_root).
{% if netboot_ready %}
kernel ${nbdmux-base}/artifacts/{{ export_name }}/vmlinuz?mac={{ mac }} boot=ramboot console=tty0 console=ttyS1,115200 console=ttyS0,115200 earlyprintk=ttyS0,115200 plymouth.enable=0 modprobe.blacklist=nouveau,rndis_host nouveau.modeset=0 systemd.gpt_auto=0 bty.nbd=tcp://{{ nbd_host }}:{{ nbd_port }} bty.image={{ export_name }} bty.overlay_size={{ overlay_size }} bty.server=${bty-base} bty.mac={{ mac }}{% if extra_cmdline %} {{ extra_cmdline }}{% endif %}
initrd ${nbdmux-base}/artifacts/{{ export_name }}/initrd?mac={{ mac }}
{% else %}
kernel ${bty-base}/boot/bty-ramboot-init-x86_64-v{{ bty_version }}.vmlinuz?mac={{ mac }} boot=ramboot console=tty0 console=ttyS1,115200 console=ttyS0,115200 earlyprintk=ttyS0,115200 plymouth.enable=0 modprobe.blacklist=nouveau,rndis_host nouveau.modeset=0 systemd.gpt_auto=0 bty.nbd=tcp://{{ nbd_host }}:{{ nbd_port }} bty.image={{ export_name }} bty.overlay_size={{ overlay_size }} bty.server=${bty-base} bty.mac={{ mac }}{% if extra_cmdline %} {{ extra_cmdline }}{% endif %}
initrd ${bty-base}/boot/bty-ramboot-init-x86_64-v{{ bty_version }}.initrd?mac={{ mac }}
{% endif %}
boot
